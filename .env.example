# HealthLens AI — Environment Variables
# Copy this file to .env and fill in your values

# ─── REQUIRED ─────────────────────────────────────────────────────────────────
# Get your FREE Groq API key at: https://console.groq.com
# No credit card required for free tier
GROQ_API_KEY=your_groq_api_key_here

# ─── OPTIONAL (leave as-is for local development) ─────────────────────────────
# Server settings
HOST=0.0.0.0
PORT=8000

# Upload limits
MAX_FILE_SIZE_MB=50

# Model selection (these are free on Groq)
# Best accuracy model (used for Agent 1 & Agent 3)
GROQ_MODEL_ACCURATE=llama-3.3-70b-versatile

# Fast model (used for Agent 2 chat)
GROQ_MODEL_FAST=llama-3.3-70b-versatile

# Database
DB_PATH=healthlens.db
